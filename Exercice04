public class Article{
    private String reference;
    private String designation ;
    private double prixHT;
    //private double tauxTVA;
    private static double tauxTVA = 40;
    public Article(){

    }
    public Article(String r, String d , double p,double t){
        reference=r;
        designation=d;
        prixHT =p;
        tauxTVA=t;
    }

    public Article(String R, String D){
        reference=R;
        designation=D;
    }
    public Article (Article A){
        this.reference= A.reference;
        this.designation=A.designation;
        this.prixHT= A.prixHT ;
        this.tauxTVA= A.tauxTVA  ;
    }
    public double CalculerPrixTTC(){
        double PrixTTC=  prixHT +(prixHT*(tauxTVA/100));
         return PrixTTC;
    }
    public void AfficherArticle(){
        System.out.println("les informations de cet article est : /n" +"Reference:"+reference+"/n"+"Designation:"+designation+"/n"+"prixHT:"+prixHT+"tauxTVA:"+tauxTVA);
    }
    //modification au niveau de class pour derniere question
    public Article(String r, String d , double p){
        reference=r;
        designation=d;
        prixHT =p;
    }
    public static void setTauxTVA(double t) {
        tauxTVA = t;
    }
}
